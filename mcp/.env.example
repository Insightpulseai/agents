# IPAI Remote MCP Connector - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# AUTH & SECURITY
# ============================================================================

# Bearer tokens with scope assignments (JSON format)
# Format: {"token_name": {"scopes": ["scope1", "scope2"]}}
ALLOWED_TOKENS='{"token_dev_abc": {"scopes": ["github:read", "odoo:read"]}}'

# Webhook bridge HMAC secret (256-bit random string)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-secure-random-string-here

# Safety level: 0=full manual, 1=read auto-approved, 2=trusted env
SAFETY_LEVEL=0

# ============================================================================
# GITHUB
# ============================================================================

# GitHub personal access token (requires repo, workflow scopes)
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub organization name
GITHUB_ORG=Insightpulseai-net

# ============================================================================
# ODOO
# ============================================================================

# Odoo XML-RPC endpoint
ODOO_URL=https://159.223.75.148

# Odoo database name
ODOO_DB=production

# Odoo admin user
ODOO_USER=admin

# Odoo admin password
ODOO_PASSWORD=your-odoo-password-here

# ============================================================================
# KUBERNETES
# ============================================================================

# Kubernetes API server URL
K8S_API_SERVER=https://k8s.insightpulseai.net

# Kubernetes service account token
K8S_TOKEN=your-k8s-token-here

# Kubernetes namespace (default)
K8S_NAMESPACE=default

# ============================================================================
# N8N
# ============================================================================

# n8n API key
N8N_API_KEY=your-n8n-api-key-here

# n8n base URL
N8N_BASE_URL=https://ipa.insightpulseai.net

# ============================================================================
# VERCEL
# ============================================================================

# Vercel API token
VERCEL_TOKEN=your-vercel-token-here

# Vercel team ID
VERCEL_TEAM_ID=your-team-id-here

# ============================================================================
# SUPABASE
# ============================================================================

# Supabase project URL
SUPABASE_URL=https://xkxyvboeubffxxbebsll.supabase.co

# Supabase service role key (for audit logs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase project reference
SUPABASE_PROJECT_REF=xkxyvboeubffxxbebsll

# Audit log table name
AUDIT_LOG_TABLE=mcp_audit_log

# ============================================================================
# DIGITALOCEAN
# ============================================================================

# DigitalOcean access token
DO_ACCESS_TOKEN=your-do-access-token-here

# DigitalOcean project ID
DO_PROJECT_ID=29cde7a1-8280-46ad-9fdf-dea7b21a7825

# ============================================================================
# RATE LIMITING (UPSTASH REDIS)
# ============================================================================

# Upstash Redis URL (for distributed rate limiting)
UPSTASH_REDIS_URL=your-upstash-redis-url-here

# ============================================================================
# OBSERVABILITY
# ============================================================================

# Mattermost webhook URL (for notifications)
MATTERMOST_WEBHOOK_URL=https://mattermost.insightpulseai.net/hooks/your-webhook-id

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# NEXT.JS (AUTO-CONFIGURED)
# ============================================================================

# Node environment (auto-detected)
# NODE_ENV=development

# Next.js base URL (auto-detected)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
