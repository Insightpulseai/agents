<odoo>
  <record id="res_config_settings_view_form_ipai_copilot" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.ipai.copilot</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form" position="inside">
        <app string="IPAI Copilot" name="ipai_copilot">
          <block title="Foundry Copilot">
            <setting string="Enable Odoo Copilot"
                     help="Enable the Foundry-backed IPAI copilot bridge.">
              <field name="ipai_copilot_enabled"/>
            </setting>
            <setting string="Backend URL"
                     help="Server-side adapter URL for the published Foundry Agent Application.">
              <field name="ipai_copilot_backend_url"/>
            </setting>
            <setting string="Environment Mode"
                     help="Default copilot environment mode.">
              <field name="ipai_copilot_environment_mode"/>
            </setting>
          </block>
        </app>
      </xpath>
    </field>
  </record>
</odoo>
